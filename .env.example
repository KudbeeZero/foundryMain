# Core Plane — Supabase Postgres connection (used by @foundry/db + drizzle-kit)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Edge/API Plane
API_PORT=8787
# Shared secret for the Beacon hook receiver (POST /hooks/beacon). Publishers send
# it as the x-beacon-token header. Leave empty to keep the receiver disabled.
BEACON_HOOK_TOKEN=

# Beacon publishers (dev machine — scripts/beacon-statusline.sh + beacon-hook.mjs).
# Point this at the receiver: localhost for same-box, or the cloudflared tunnel URL
# (`pnpm tunnel`) for a remote dev box. Publishing is best-effort / fail-open.
FOUNDRY_BEACON_URL=http://localhost:8787

# Persist accepted Beacon events to beacon_events + enable GET /hooks/beacon/replay
# (requires DATABASE_URL). Off by default so dev/CI run with no database.
BEACON_PERSIST=false

# Supabase JWT secret used to verify the HS256 Bearer token on /api/* (the API
# expects `sub` + a custom `org_id` claim). The default is dev-insecure — set a
# real secret in any shared/production environment.
SUPABASE_JWT_SECRET=dev-insecure-secret

# Anthropic API key for the agent-runner's real model runs (Execution plane).
# Unset → the worker reasons with no model (placeholder lifecycle) and never calls
# the API. Set it to enable real claude-opus-4-8 runs. Real model spend.
ANTHROPIC_API_KEY=

# Orchestration Plane — BullMQ / Redis
REDIS_URL=redis://localhost:6379

# Execution Plane — Anthropic, GitHub App (filled in their stages)
ANTHROPIC_API_KEY=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# PR hygiene sweep (scripts/pr-sweep.ts)
GITHUB_TOKEN=
FOUNDRY_REPOS=owner/repo1,owner/repo2
