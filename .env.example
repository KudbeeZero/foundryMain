# Core Plane — Supabase Postgres connection (used by @foundry/db + drizzle-kit)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Edge/API Plane
API_PORT=8787

# Orchestration Plane — BullMQ / Redis
REDIS_URL=redis://localhost:6379

# Execution Plane — Anthropic, GitHub App (filled in their stages)
ANTHROPIC_API_KEY=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# PR hygiene sweep (scripts/pr-sweep.ts)
GITHUB_TOKEN=
FOUNDRY_REPOS=owner/repo1,owner/repo2
