{
  "// note": "Example Foundry Beacon wiring for Claude Code. Copy the relevant bits into your real .claude/settings.json. Set FOUNDRY_BEACON_URL + BEACON_HOOK_TOKEN in your environment (point FOUNDRY_BEACON_URL at the cloudflared tunnel from `pnpm tunnel`). Publishing is best-effort and never blocks the session.",
  "statusLine": {
    "type": "command",
    "command": "bash scripts/beacon-statusline.sh"
  },
  "hooks": {
    "SessionStart": [{ "hooks": [{ "type": "command", "command": "node scripts/beacon-hook.mjs SessionStart" }] }],
    "UserPromptSubmit": [{ "hooks": [{ "type": "command", "command": "node scripts/beacon-hook.mjs UserPromptSubmit" }] }],
    "PreToolUse": [{ "hooks": [{ "type": "command", "command": "node scripts/beacon-hook.mjs PreToolUse" }] }],
    "PostToolUse": [{ "hooks": [{ "type": "command", "command": "node scripts/beacon-hook.mjs PostToolUse" }] }],
    "Notification": [{ "hooks": [{ "type": "command", "command": "node scripts/beacon-hook.mjs Notification" }] }],
    "SubagentStop": [{ "hooks": [{ "type": "command", "command": "node scripts/beacon-hook.mjs SubagentStop" }] }],
    "Stop": [{ "hooks": [{ "type": "command", "command": "node scripts/beacon-hook.mjs Stop" }] }]
  }
}
